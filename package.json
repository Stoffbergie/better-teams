{
  "name": "better-teams",
  "productName": "Better Teams",
  "version": "1.0.4",
  "description": "A calmer, faster Microsoft Teams desktop experience with a focused custom UI",
  "private": true,
  "scripts": {
    "branding:generate": "node scripts/generate-branding.mjs",
    "dev": "electron-forge start",
    "start": "electron-forge start",
    "typecheck": "bun run --cwd packages/core typecheck && bun run --cwd packages/ui typecheck && bun run --cwd packages/app typecheck && bun run --cwd packages/desktop-electron typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "doctor": "react-doctor --no-score --blocking error --no-warnings --no-dead-code --yes",
    "test": "bun run --cwd packages/core test && bun run --cwd packages/app test && bun run --cwd packages/desktop-electron test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "package": "electron-forge package",
    "build": "electron-forge package",
    "verify": "bun run typecheck && bun run check && bun run doctor && bun run test:coverage && bun run build",
    "audit": "bun audit",
    "lefthook:install": "lefthook install",
    "vite:dev": "vite --config packages/app/vite.config.mts --host 127.0.0.1",
    "vite:build": "vite build --config packages/app/vite.config.mts",
    "make": "electron-forge make",
    "test:unit": "bun run test"
  },
  "author": "Dirk Beukes",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^42.4.1",
    "happy-dom": "^20.10.6",
    "knip": "^6.17.1",
    "lefthook": "^2.1.9",
    "react-doctor": "^0.5.8",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@radix-ui/react-avatar": "1.1.10",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-separator": "1.1.7",
    "@radix-ui/react-slot": "1.2.3",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-query": "^5.95.2",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.562.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "main": ".vite/build/main.js",
  "workspaces": [
    "packages/*"
  ]
}
